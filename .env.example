# Used by Docker Compose for variable substitution (copy to `.env` in repo root).
#
# If `npm run db:up` fails with "address already in use" on 5432, another Postgres
# (Homebrew, Postgres.app, etc.) is using that port. Pick a free host port and set
# the same port in `backend/.env` → DATABASE_URL (e.g. ...@localhost:5433/finbar).
#
# FINBAR_PG_PUBLISH_PORT=5433
