# === Finbar op VPS: kopieer naar map met compose als `.env` en vul in ===
#
# DATABASE_URL: hostnaam `postgres` = servicenaam in deploy/compose.production.yaml
# JWT_SECRET: minimaal 32 willekeurige tekens in productie
# PUBLIC_APP_URL: exact je publieke URL (https, zonder pad)

NODE_ENV=production
HOST=0.0.0.0
PORT=3001
STATIC_DIR=/app/static

POSTGRES_USER=finbar
POSTGRES_PASSWORD=vervang_door_zeer_lang_wachtwoord
POSTGRES_DB=finbar

DATABASE_URL=postgresql://finbar:ZELFDE_ALS_HIERBOVEN@postgres:5432/finbar

JWT_SECRET=vervang_door_minstens_32_tekens_willekeurig

PUBLIC_APP_URL=https://finbar.diversepersonality.com

# Optioneel: Resend voor wachtwoord-reset
# RESEND_API_KEY=
# RESEND_FROM=Finbar <noreply@jouwdomein.tld>

# Image van ghcr (kleine letters); moet overeenkomen met wat CI pusht
FINBAR_IMAGE=ghcr.io/antonsprojects/finbar:latest
# Map op de host: alleen 127.0.0.1, reverse proxy ernaast
# FINBAR_PUBLISH_PORT=8080
