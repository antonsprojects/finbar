# Nginx: reverse proxy voor Finbar (Docker bindt 127.0.0.1:8080 → app-poort 3001)
#
# 1) Pas server_name en poort aan (8080 = FINBAR_PUBLISH_PORT in .env)
# 2) Kopieer na /etc/nginx/sites-available/finbar (of conf.d/ op RHEL)
# 3) sudo nginx -t && sudo systemctl reload nginx
# 4) TLS: certbot (zie docs/deploy-vps.md)

upstream finbar_upstream {
    server 127.0.0.1:8080;
    keepalive 16;
}

# HTTP: tijdens setup of voor ACME; daarna 301 naar HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name finbar.diversepersonality.com;

    # Certbot (webroot) — pad aanmaken: sudo mkdir -p /var/www/html
    # location ^~ /.well-known/acme-challenge/ { root /var/www/html; }

    location / {
        proxy_pass http://finbar_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        # SPA + API: geen extra buffering vereist; verhoog bij grote uploads:
        # client_max_body_size 20m;
    }
}

# Na certbot: voeg server { listen 443 ssl; ... } toe of laat certbot de file uitbreiden.
# Voorbeeld handmatige SSL (paden = output van certbot):
#
# server {
#     listen 443 ssl;
#     listen [::]:443 ssl;
#     http2 on;
#     server_name finbar.diversepersonality.com;
#     ssl_certificate     /etc/letsencrypt/live/finbar.diversepersonality.com/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/finbar.diversepersonality.com/privkey.pem;
#     include /etc/letsencrypt/options-ssl-nginx.conf;
#     ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
#     location / { ... zelfde proxy_* als boven ... }
# }
