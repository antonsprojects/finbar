// Finbar MVP — Block 06. Worker availability: AVAILABLE | UNAVAILABLE only (no "booked").

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum AccountRole {
  USER
  ADMIN
}

/// Per calendar day: can we plan this worker or not? (Exceptions override recurring patterns in the UI later.)
enum WorkerAvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
}

/// Een reeks dagen: deeltijd in een periode, of aanduiding vaste dienst (o.a. teamlid bewerken).
enum WorkerAvailabilityPeriodKind {
  PART_TIME
  FIXED_SHIFT
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String      @map("password_hash")
  role         AccountRole @default(USER)
  firstName    String?     @map("first_name")
  lastName     String?     @map("last_name")
  /// Getoond als app-naam in de globale header; leeg = standaard “Finbar”.
  companyName  String?     @map("company_name")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  jobs                      Job[]
  workers                   Worker[]
  tasks                     Task[]
  scheduleAssignments       ScheduleAssignment[]
  workerAvailabilities      WorkerAvailability[]
  preference                UserPreference?
  passwordResetTokens       PasswordResetToken[]
  workerAvailabilityPeriods WorkerAvailabilityPeriod[]
  jobTeamMembers            JobTeamMember[]
  createdInvites            Invite[]                   @relation("InviteCreatedByAdmin")
  usedInvites               Invite[]                   @relation("InviteUsedByUser")
}

model Invite {
  id               String    @id @default(cuid())
  email            String
  codeHash         String    @unique @map("code_hash")
  createdByAdminId String    @map("created_by_admin_id")
  createdByAdmin   User      @relation("InviteCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: Cascade)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  usedAt           DateTime? @map("used_at")
  usedByUserId     String?   @map("used_by_user_id")
  usedByUser       User?     @relation("InviteUsedByUser", fields: [usedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([createdByAdminId])
  @@index([expiresAt])
  @@index([usedByUserId])
  @@map("invites")
}

/// One-time token to set a new password (raw token only in e-mail; we store SHA-256).
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model UserPreference {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  largeTextMode Boolean  @default(false)
  preferredView String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Job {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  status    JobStatus @default(PLANNING)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tasks               Task[]
  scheduleAssignments ScheduleAssignment[]
  teamMembers         JobTeamMember[]
  budgetPhases        BudgetPhase[]

  @@index([userId])
}

model Worker {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String   @default("")
  /// Vakgebieden / tags (los van elkaar; legacy comma-separated values bij migratie gesplitst).
  trades    String[] @default([])
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskAssignees       TaskAssignee[]
  scheduleAssignments ScheduleAssignment[]
  teamMemberships     JobTeamMember[]
  availabilities      WorkerAvailability[]
  availabilityPeriods WorkerAvailabilityPeriod[]

  @@index([userId])
}

/// Work item on a job. Optional assignees + date; separate from schedule (crew on site per day).
model Task {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  /// Optioneel: begrotingsregel waar deze dagtaak van afkomstig is; voorkomt dubbele planning op dezelfde dag.
  budgetLineId  String?        @map("budget_line_id")
  budgetLine    BudgetLine?    @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  title         String
  description   String?
  status        TaskStatus     @default(OPEN)
  scheduledDate DateTime?      @db.Date
  assignees     TaskAssignee[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  completedAt   DateTime?

  @@unique([userId, jobId, scheduledDate, budgetLineId])
  @@index([userId])
  @@index([jobId])
  @@index([budgetLineId])
}

/// Many-to-many: welke teamleden horen bij deze taak.
model TaskAssignee {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, workerId])
  @@index([taskId])
  @@index([workerId])
}

/// Contact op het projectteam (zonder impliciete dagmaand). Inplanning = ScheduleAssignment.
model JobTeamMember {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String   @map("job_id")
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerId  String   @map("worker_id")
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([jobId, workerId])
  @@index([userId])
  @@index([jobId])
  @@map("job_team_members")
}

/// Who is on which job on which calendar day (planning / crew). Separate from Task-assignees.
model ScheduleAssignment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workerId, jobId, date])
  @@index([userId])
  @@index([date])
}

/// Availability for a worker on a calendar day — not "booked"; use schedule assignments for who is planned.
model WorkerAvailability {
  id        String                   @id @default(cuid())
  userId    String
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerId  String
  worker    Worker                   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  date      DateTime                 @db.Date
  status    WorkerAvailabilityStatus
  notes     String?
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@unique([workerId, date])
  @@index([userId])
  @@index([date])
}

/// Beschikbaarheid als datumbereik (deeltijd) of vaste dienst — naast de dag-cellen in de weekweergave.
model WorkerAvailabilityPeriod {
  id        String                       @id @default(cuid())
  userId    String
  user      User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerId  String
  worker    Worker                       @relation(fields: [workerId], references: [id], onDelete: Cascade)
  dateFrom  DateTime                     @db.Date
  /// Bij vaste dienst: `null` = onbepaard (geen einddatum). Deeltijd heeft altijd een einddatum.
  dateTo    DateTime?                    @db.Date
  kind      WorkerAvailabilityPeriodKind
  notes     String?
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt

  @@index([userId])
  @@index([workerId])
  @@index([workerId, dateFrom])
}

/// Fase binnen de begroting van een project (bv. Badkamer, Keuken).
model BudgetPhase {
  id        String       @id @default(cuid())
  jobId     String       @map("job_id")
  job       Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int          @default(0) @map("sort_order")
  lines     BudgetLine[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([jobId])
  @@map("budget_phases")
}

/// Begrotingsregel (ToDo binnen een fase): uren, uurloon, materialen, materiaalkosten.
model BudgetLine {
  id                   String      @id @default(cuid())
  phaseId              String      @map("phase_id")
  phase                BudgetPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  tasks                Task[]
  title                String
  hours                Decimal     @default(0) @db.Decimal(10, 2)
  hourlyRate           Decimal     @default(0) @map("hourly_rate") @db.Decimal(10, 2)
  materialsDescription String?     @map("materials_description")
  materialCost         Decimal     @default(0) @map("material_cost") @db.Decimal(10, 2)
  sortOrder            Int         @default(0) @map("sort_order")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  @@index([phaseId])
  @@map("budget_lines")
}
