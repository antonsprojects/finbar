# Local stack: API 3001 (avoids clash with apps on 3000), frontend 5173 — see docs/local-development.md
NODE_ENV=development
HOST=0.0.0.0
PORT=3001

# Postgres URL: use a dedicated USER + DATABASE on your existing server (recommended), or
# match Docker Compose (finbar/finbar@localhost — adjust port if FINBAR_PG_PUBLISH_PORT is set).
# Example (existing Postgres): postgresql://finbar:YOUR_PASSWORD@localhost:5432/finbar
DATABASE_URL=postgresql://finbar:finbar@localhost:5432/finbar

# JWT signing secret for httpOnly cookie sessions (use a long random string in production).
JWT_SECRET=change-me-to-a-long-random-secret-at-least-16-chars

# Base URL of the web app (no trailing slash). Used in password-reset e-mails and CORS in production.
PUBLIC_APP_URL=http://localhost:5173

# Optional: absolute path to Vite `dist` for serving the SPA from the API (Docker sets this; omit locally).
# STATIC_DIR=/app/static

# Password-reset e-mail (optional). Without RESEND_API_KEY, reset links are only written to the
# API server log — you will not receive anything in your inbox.
# 1. Create a free account at https://resend.com and create an API key.
# 2. Set RESEND_API_KEY below. Use RESEND_FROM=Finbar <onboarding@resend.dev> for quick tests
#    (Resend may only allow sending to your own e-mail until you verify a domain).
# 3. PUBLIC_APP_URL must match where users open the app (e.g. https://yourdomain.com).
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Finbar <onboarding@resend.dev>
