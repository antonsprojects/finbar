# Local stack ports: API 3000, Postgres 5432, frontend 5173 — see docs/local-development.md
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Matches root docker-compose.yml (user/password/db: finbar). Host is localhost when API runs on your machine.
DATABASE_URL=postgresql://finbar:finbar@localhost:5432/finbar
