# Local stack ports: API 3000, frontend 5173 — see docs/local-development.md
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Matches Docker Compose (user/password/db: finbar). Port must match FINBAR_PG_PUBLISH_PORT
# in repo-root `.env` (default 5432). If you map host 5433 → container 5432, use :5433 here.
DATABASE_URL=postgresql://finbar:finbar@localhost:5432/finbar
